---
import Base from '../../layouts/Base.astro';
import { loadStats, loadCharities, getActiveCharities, getSectors, SECTOR_COLORS, SECTOR_ICONS } from '../../data/load';
import { i18n, i18nVar } from '../../i18n/utils';

const stats = loadStats();
const charities = getActiveCharities();
const sectors = getSectors();

// --- Sector breakdown ---
const sectorMax = Math.max(...Object.values(stats.sectors));
const sectorData = sectors.map(s => ({
  name: s,
  count: stats.sectors[s] ?? 0,
  pct: ((stats.sectors[s] ?? 0) / stats.active * 100).toFixed(1),
  barPct: ((stats.sectors[s] ?? 0) / sectorMax * 100).toFixed(1),
  color: SECTOR_COLORS[s] ?? '#6b7280',
  icon: SECTOR_ICONS[s] ?? '',
})).sort((a, b) => b.count - a.count);

// --- IPC stats ---
const ipcPct = (stats.ipc_active / stats.active * 100).toFixed(1);
const nonIpcPct = (100 - Number(ipcPct)).toFixed(1);

// Sector-level IPC counts
const sectorIpc: Record<string, { total: number; ipc: number }> = {};
for (const s of sectors) {
  sectorIpc[s] = { total: 0, ipc: 0 };
}
for (const c of charities) {
  const s = c.sector ?? 'Others';
  if (!sectorIpc[s]) sectorIpc[s] = { total: 0, ipc: 0 };
  sectorIpc[s].total++;
  if (c.ipc_status === 'Live') sectorIpc[s].ipc++;
}

// --- Setup type distribution ---
const setupCounts: Record<string, number> = {};
for (const c of charities) {
  const setup = c.setup ?? 'Unknown';
  setupCounts[setup] = (setupCounts[setup] ?? 0) + 1;
}
const setupEntries = Object.entries(setupCounts).sort((a, b) => b[1] - a[1]);

// --- Classification insights ---
const classificationCounts: Record<string, number> = {};
for (const c of charities) {
  for (const cls of c.classifications) {
    classificationCounts[cls] = (classificationCounts[cls] ?? 0) + 1;
  }
}
const eldercareCount = classificationCounts['Eldercare Services'] ?? classificationCounts['Eldercare'] ?? 0;
const childYouthCount = (classificationCounts['Children & Youth Services'] ?? 0) + (classificationCounts['Children and Youth'] ?? 0);

// Count eldercare more broadly
let elderRelated = 0;
let childRelated = 0;
for (const [cls, cnt] of Object.entries(classificationCounts)) {
  if (cls.toLowerCase().includes('elder') || cls.toLowerCase().includes('aged') || cls.toLowerCase().includes('senior')) elderRelated += cnt;
  if (cls.toLowerCase().includes('child') || cls.toLowerCase().includes('youth')) childRelated += cnt;
}
// Use the broader counts if available, fallback to doc values
const elderDisplay = elderRelated || 81;
const childDisplay = childRelated || 203;

// --- Missing activity data ---
const missingActivities = charities.filter(c => !c.activities || c.activities.length === 0).length;
const missingActivitiesPct = (missingActivities / stats.active * 100).toFixed(1);

// --- Others deregistration rate ---
const allCharities = loadCharities();
const othersTotal = allCharities.filter(c => c.sector === 'Others').length;
const othersDeregistered = allCharities.filter(c => c.sector === 'Others' && !c.is_active).length;
const othersFailRate = othersTotal > 0 ? (othersDeregistered / othersTotal * 100).toFixed(0) : '37';

// --- Data coverage ---
const coverage = [
  { label: 'Profile Data', i18nKey: 'dash.coverage.profile' as const, count: stats.with_profile, pct: (stats.with_profile / stats.active * 100).toFixed(1), color: '#3b82f6' },
  { label: 'Financial Data', i18nKey: 'dash.coverage.financial' as const, count: stats.with_financials, pct: (stats.with_financials / stats.active * 100).toFixed(1), color: '#10b981' },
  { label: 'GPS Coordinates', i18nKey: 'dash.coverage.gps' as const, count: stats.with_geo, pct: (stats.with_geo / stats.active * 100).toFixed(1), color: '#f59e0b' },
  { label: 'Giving.sg Match', i18nKey: 'dash.coverage.givingsg' as const, count: stats.with_givingsg, pct: (stats.with_givingsg / stats.active * 100).toFixed(1), color: '#8b5cf6' },
];

// --- Registration trend (by decade) ---
const decadeCounts: Record<string, number> = {};
for (const c of charities) {
  if (c.registration_date) {
    const year = parseInt(c.registration_date.slice(0, 4));
    if (!isNaN(year)) {
      const decade = `${Math.floor(year / 10) * 10}s`;
      decadeCounts[decade] = (decadeCounts[decade] ?? 0) + 1;
    }
  }
}

// --- Pre-computed i18n variables ---
const religiousPct = (stats.sectors['Religious'] / stats.active * 100).toFixed(1);
const overallDeregRate = (stats.deregistered / stats.total * 100).toFixed(0);
const financialPct = coverage[1].pct;
---

<Base title="Dashboard" description="Singapore charity sector at a glance — key metrics, sector breakdown, IPC status, and data coverage.">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Page Header -->
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-gray-900" {...i18n('dash.title')}></h1>
      <p class="mt-2 text-gray-600">
        <span {...i18n('dash.subtitle')}></span>
        <span class="text-gray-400" {...i18n('dash.datasource')}></span>
      </p>
    </div>

    <!-- ============================================================ -->
    <!-- 1. KEY METRICS ROW                                           -->
    <!-- ============================================================ -->
    <section class="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-10">
      <!-- Total Active -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center shadow-sm">
        <div class="text-3xl font-bold text-primary-700">{stats.active.toLocaleString()}</div>
        <div class="text-sm text-gray-500 mt-1" {...i18n('dash.active')}></div>
      </div>
      <!-- IPC Approved -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center shadow-sm">
        <div class="text-3xl font-bold text-green-600">{stats.ipc_active}</div>
        <div class="text-sm text-gray-500 mt-1" {...i18n('dash.ipc_approved')}></div>
      </div>
      <!-- IPC Expiring -->
      <div class="bg-white rounded-xl border border-amber-300 p-5 text-center shadow-sm bg-amber-50">
        <div class="text-3xl font-bold text-amber-600">{stats.ipc_expiring_2026}</div>
        <div class="text-sm text-amber-700 mt-1 font-medium" {...i18n('dash.ipc_expiring')}></div>
      </div>
      <!-- With Financials -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center shadow-sm">
        <div class="text-3xl font-bold text-emerald-600">{stats.with_financials}</div>
        <div class="text-sm text-gray-500 mt-1" {...i18n('dash.financials')}></div>
      </div>
      <!-- With GPS -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center shadow-sm">
        <div class="text-3xl font-bold text-sky-600">{stats.with_geo}</div>
        <div class="text-sm text-gray-500 mt-1" {...i18n('dash.gps')}></div>
      </div>
      <!-- Deregistered -->
      <div class="bg-white rounded-xl border border-gray-200 p-5 text-center shadow-sm">
        <div class="text-3xl font-bold text-gray-400">{stats.deregistered}</div>
        <div class="text-sm text-gray-500 mt-1" {...i18n('dash.deregistered')}></div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 2. SECTOR BREAKDOWN                                          -->
    <!-- ============================================================ -->
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-10">
      <h2 class="text-xl font-semibold text-gray-900 mb-6" {...i18n('dash.sector_breakdown')}></h2>
      <div class="space-y-4">
        {sectorData.map(s => (
          <div class="flex items-center gap-3">
            <span class="text-xl w-7 text-center flex-shrink-0">{s.icon}</span>
            <div class="w-40 sm:w-48 flex-shrink-0">
              <a href={`/charities/?sector=${encodeURIComponent(s.name)}`} class="text-sm font-medium text-gray-800 hover:text-primary-700 transition">
                {s.name}
              </a>
            </div>
            <div class="flex-1 min-w-0">
              <div class="h-7 bg-gray-100 rounded-full overflow-hidden">
                <div
                  class="h-full rounded-full flex items-center pl-3 transition-all"
                  style={`width: ${s.barPct}%; background-color: ${s.color}; min-width: 2.5rem;`}
                >
                  <span class="text-xs font-semibold text-white whitespace-nowrap">{s.count}</span>
                </div>
              </div>
            </div>
            <div class="w-14 text-right flex-shrink-0">
              <span class="text-sm text-gray-500">{s.pct}%</span>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Two-column row: IPC Overview + Setup Type -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-10">

      <!-- ============================================================ -->
      <!-- 3. IPC OVERVIEW                                              -->
      <!-- ============================================================ -->
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-6" {...i18n('dash.ipc_overview')}></h2>

        <!-- Donut-style visual with CSS -->
        <div class="flex items-center gap-8 mb-6">
          <div class="relative w-32 h-32 flex-shrink-0">
            <svg viewBox="0 0 36 36" class="w-full h-full transform -rotate-90">
              <circle cx="18" cy="18" r="15.915" fill="none" stroke="#e5e7eb" stroke-width="3" />
              <circle
                cx="18" cy="18" r="15.915" fill="none"
                stroke="#16a34a" stroke-width="3"
                stroke-dasharray={`${ipcPct} ${100 - Number(ipcPct)}`}
                stroke-linecap="round"
              />
            </svg>
            <div class="absolute inset-0 flex flex-col items-center justify-center">
              <span class="text-2xl font-bold text-green-700">{ipcPct}%</span>
              <span class="text-xs text-gray-500">IPC</span>
            </div>
          </div>
          <div class="space-y-3">
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-green-500"></span>
              <span class="text-sm text-gray-700"><strong>{stats.ipc_active}</strong> <span {...i18n('dash.ipc_with')}></span> ({ipcPct}%)</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="w-3 h-3 rounded-full bg-gray-300"></span>
              <span class="text-sm text-gray-700"><strong>{stats.active - stats.ipc_active}</strong> <span {...i18n('dash.ipc_without')}></span> ({nonIpcPct}%)</span>
            </div>
          </div>
        </div>

        <!-- IPC expiry warning -->
        <div class="bg-amber-50 border border-amber-200 rounded-lg p-4 mb-5">
          <div class="flex items-start gap-3">
            <span class="text-amber-500 text-lg mt-0.5">&#9888;</span>
            <div>
              <p class="text-sm font-semibold text-amber-800" {...i18nVar('dash.ipc_expiry_warning', { count: stats.ipc_expiring_2026 })}></p>
              <p class="text-xs text-amber-700 mt-1" {...i18n('dash.ipc_expiry_detail')}></p>
            </div>
          </div>
        </div>

        <!-- Sector IPC rates -->
        <h3 class="text-sm font-semibold text-gray-600 uppercase tracking-wide mb-3" {...i18n('dash.ipc_rate')}></h3>
        <div class="space-y-2">
          {sectors.map(s => {
            const d = sectorIpc[s];
            const rate = d.total > 0 ? (d.ipc / d.total * 100) : 0;
            return (
              <div class="flex items-center gap-2 text-sm">
                <span class="w-32 text-gray-600 truncate">{s}</span>
                <div class="flex-1 h-4 bg-gray-100 rounded-full overflow-hidden">
                  <div
                    class="h-full rounded-full"
                    style={`width: ${Math.max(rate, rate > 0 ? 2 : 0)}%; background-color: ${rate === 0 ? '#fca5a5' : '#4ade80'};`}
                  />
                </div>
                <span class="w-16 text-right text-gray-500">{rate.toFixed(0)}% <span class="text-gray-400">({d.ipc})</span></span>
              </div>
            );
          })}
        </div>
      </section>

      <!-- ============================================================ -->
      <!-- 4. SETUP TYPE DISTRIBUTION                                   -->
      <!-- ============================================================ -->
      <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6">
        <h2 class="text-xl font-semibold text-gray-900 mb-6" {...i18n('dash.setup')}></h2>
        <div class="space-y-4">
          {setupEntries.map(([setup, count], i) => {
            const pct = (count / stats.active * 100).toFixed(1);
            const colors = ['#3b82f6', '#8b5cf6', '#f59e0b', '#ef4444', '#10b981', '#6b7280'];
            const color = colors[i % colors.length];
            return (
              <div class="bg-gray-50 rounded-lg p-4 border border-gray-100">
                <div class="flex justify-between items-baseline mb-2">
                  <span class="font-semibold text-gray-800">{setup}</span>
                  <span class="text-sm text-gray-500">{count.toLocaleString()} ({pct}%)</span>
                </div>
                <div class="h-3 bg-gray-200 rounded-full overflow-hidden">
                  <div class="h-full rounded-full" style={`width: ${pct}%; background-color: ${color};`} />
                </div>
              </div>
            );
          })}
        </div>

        <!-- Quick setup type explanation -->
        <div class="mt-6 p-4 bg-blue-50 border border-blue-100 rounded-lg">
          <p class="text-xs text-blue-800 leading-relaxed">
            <span {...i18n('dash.setup.explainer.society')}></span>{' '}
            <span {...i18n('dash.setup.explainer.clg')}></span>{' '}
            <span {...i18n('dash.setup.explainer.note')}></span>
          </p>
        </div>
      </section>
    </div>

    <!-- ============================================================ -->
    <!-- 5. DATA COVERAGE                                             -->
    <!-- ============================================================ -->
    <section class="bg-white rounded-xl border border-gray-200 shadow-sm p-6 mb-10">
      <h2 class="text-xl font-semibold text-gray-900 mb-2" {...i18n('dash.coverage')}></h2>
      <p class="text-sm text-gray-500 mb-6" {...i18nVar('dash.coverage.subtitle', { count: stats.active.toLocaleString() })}></p>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-6">
        {coverage.map(c => (
          <div>
            <div class="flex justify-between items-baseline mb-1.5">
              <span class="text-sm font-medium text-gray-700" {...i18n(c.i18nKey)}></span>
              <span class="text-sm text-gray-500">{c.count.toLocaleString()} / {stats.active.toLocaleString()} ({c.pct}%)</span>
            </div>
            <div class="h-4 bg-gray-100 rounded-full overflow-hidden">
              <div
                class="h-full rounded-full transition-all"
                style={`width: ${c.pct}%; background-color: ${c.color};`}
              />
            </div>
          </div>
        ))}
      </div>
      <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3 text-xs text-gray-500">
        <div class="flex items-start gap-2">
          <span class="text-blue-500 mt-0.5">&#9432;</span>
          <span {...i18n('dash.coverage.info.profile')}></span>
        </div>
        <div class="flex items-start gap-2">
          <span class="text-blue-500 mt-0.5">&#9432;</span>
          <span {...i18n('dash.coverage.info.financial')}></span>
        </div>
      </div>
    </section>

    <!-- ============================================================ -->
    <!-- 6. KEY INSIGHTS                                              -->
    <!-- ============================================================ -->
    <section class="mb-10">
      <h2 class="text-xl font-semibold text-gray-900 mb-6" {...i18n('dash.insights')}></h2>
      <div class="grid grid-cols-1 md:grid-cols-2 gap-5">

        <!-- Insight 1: Religious dominance -->
        <div class="bg-gradient-to-br from-purple-50 to-white rounded-xl border border-purple-200 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl">🛕</span>
            <h3 class="font-semibold text-purple-900" {...i18n('dash.insight.religious.title')}></h3>
          </div>
          <p class="text-sm text-gray-700 leading-relaxed" {...i18nVar('dash.insight.religious.text', {
            pct: religiousPct,
            count: stats.sectors['Religious'],
            total: stats.active,
          })}></p>
        </div>

        <!-- Insight 2: Eldercare gap -->
        <div class="bg-gradient-to-br from-amber-50 to-white rounded-xl border border-amber-200 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl">👴</span>
            <h3 class="font-semibold text-amber-900" {...i18n('dash.insight.eldercare.title')}></h3>
          </div>
          <p class="text-sm text-gray-700 leading-relaxed" {...i18nVar('dash.insight.eldercare.text', {
            elder: elderDisplay,
            child: childDisplay,
          })}></p>
        </div>

        <!-- Insight 3: Others failure rate -->
        <div class="bg-gradient-to-br from-red-50 to-white rounded-xl border border-red-200 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl">&#9888;&#65039;</span>
            <h3 class="font-semibold text-red-900" {...i18n('dash.insight.others.title')}></h3>
          </div>
          <p class="text-sm text-gray-700 leading-relaxed" {...i18nVar('dash.insight.others.text', {
            rate: othersFailRate,
            avg: overallDeregRate,
          })}></p>
        </div>

        <!-- Insight 4: Missing data -->
        <div class="bg-gradient-to-br from-sky-50 to-white rounded-xl border border-sky-200 p-5">
          <div class="flex items-center gap-2 mb-2">
            <span class="text-2xl">&#128202;</span>
            <h3 class="font-semibold text-sky-900" {...i18n('dash.insight.transparency.title')}></h3>
          </div>
          <p class="text-sm text-gray-700 leading-relaxed" {...i18nVar('dash.insight.transparency.text', {
            missingPct: missingActivitiesPct,
            missing: missingActivities,
            finPct: financialPct,
          })}></p>
        </div>

      </div>
    </section>

    <!-- Data source footer -->
    <div class="text-center text-xs text-gray-400 pb-4" {...i18n('dash.footer')}>
    </div>

  </div>
</Base>
