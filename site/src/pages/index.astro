---
import Base from '../layouts/Base.astro';
import { loadStats, getSectors, SECTOR_ICONS, SECTOR_COLORS } from '../data/load';
import { i18n, i18nVar } from '../i18n/utils';

const stats = loadStats();
const sectors = getSectors();
---

<Base title="Home" description="Explore Singapore's 2,600+ registered charities — search by sector, check IPC status, compare financials, and discover transparent organisations.">

  <!-- Hero -->
  <section class="bg-gradient-to-br from-primary-700 via-primary-800 to-primary-900 text-white">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-20 md:py-28">
      <div class="max-w-3xl">
        <h1 class="text-4xl md:text-5xl font-bold tracking-tight leading-tight">
          SG Charity Map
          <span class="block text-primary-200 text-2xl md:text-3xl mt-2 font-medium" {...i18n('home.subtitle')}></span>
        </h1>
        <p class="mt-6 text-lg md:text-xl text-primary-100 leading-relaxed" {...i18nVar('home.description', { count: stats.active.toLocaleString(), sectors: sectors.length })}></p>
        <div class="mt-8 flex flex-col sm:flex-row gap-4">
          <a
            href="/charities/"
            class="inline-flex items-center justify-center px-6 py-3 bg-white text-primary-700 font-semibold rounded-lg hover:bg-primary-50 transition shadow-lg"
          >
            <span {...i18n('home.cta.browse')}></span>
            <svg class="w-5 h-5 ml-2" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
          </a>
          <a
            href="/dashboard/"
            class="inline-flex items-center justify-center px-6 py-3 border-2 border-primary-300 text-white font-semibold rounded-lg hover:bg-primary-600 transition"
            {...i18n('home.cta.dashboard')}
          >
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- Key Stats -->
  <section class="relative -mt-8 z-10">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
        <div class="bg-white rounded-xl shadow-md p-6 text-center border border-gray-100">
          <p class="text-3xl md:text-4xl font-bold text-primary-700">{stats.active.toLocaleString()}</p>
          <p class="text-sm text-gray-500 mt-1" {...i18n('home.stats.active')}></p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-6 text-center border border-gray-100">
          <p class="text-3xl md:text-4xl font-bold text-primary-700">{stats.ipc_active.toLocaleString()}</p>
          <p class="text-sm text-gray-500 mt-1" {...i18n('home.stats.ipc')}></p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-6 text-center border border-gray-100">
          <p class="text-3xl md:text-4xl font-bold text-primary-700">{sectors.length}</p>
          <p class="text-sm text-gray-500 mt-1" {...i18n('home.stats.sectors')}></p>
        </div>
        <div class="bg-white rounded-xl shadow-md p-6 text-center border border-gray-100">
          <p class="text-3xl md:text-4xl font-bold text-amber-600">{stats.ipc_expiring_2026.toLocaleString()}</p>
          <p class="text-sm text-gray-500 mt-1" {...i18n('home.stats.expiring')}></p>
        </div>
      </div>
    </div>
  </section>

  <!-- Quick Search -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="bg-white rounded-2xl shadow-sm border border-gray-200 p-8 md:p-10">
      <h2 class="text-2xl font-bold text-gray-900 text-center" {...i18n('home.search.title')}></h2>
      <p class="text-gray-500 text-center mt-2" {...i18n('home.search.subtitle')}></p>
      <form id="search-form" class="mt-6 max-w-2xl mx-auto flex gap-3">
        <div class="relative flex-1">
          <svg class="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/></svg>
          <input
            id="search-input"
            type="text"
            placeholder="e.g. Red Cross, education, elderly care..."
            data-i18n-placeholder
            data-placeholder-en="e.g. Red Cross, education, elderly care..."
            data-placeholder-zh="如：红十字会、教育、养老..."
            class="w-full pl-12 pr-4 py-3 border border-gray-300 rounded-lg focus:ring-2 focus:ring-primary-500 focus:border-primary-500 text-base outline-none transition"
          />
        </div>
        <button
          type="submit"
          class="px-6 py-3 bg-primary-600 text-white font-semibold rounded-lg hover:bg-primary-700 transition whitespace-nowrap"
          {...i18n('home.search.button')}
        >
        </button>
      </form>
    </div>
  </section>

  <!-- Sector Breakdown -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-16">
    <div class="text-center mb-10">
      <h2 class="text-2xl md:text-3xl font-bold text-gray-900" {...i18n('home.sectors.title')}></h2>
    </div>
    <div class="grid grid-cols-2 md:grid-cols-4 gap-4 md:gap-6">
      {sectors.map(sector => {
        const count = stats.sectors[sector] || 0;
        const icon = SECTOR_ICONS[sector] || '📋';
        const color = SECTOR_COLORS[sector] || '#6b7280';
        return (
          <a
            href={`/charities/?sector=${encodeURIComponent(sector)}`}
            class="group bg-white rounded-xl border border-gray-200 p-6 hover:shadow-lg hover:border-primary-300 transition-all duration-200"
          >
            <div class="text-3xl mb-3">{icon}</div>
            <h3 class="font-semibold text-gray-900 group-hover:text-primary-700 transition">{sector}</h3>
            <p class="text-2xl font-bold mt-2" style={`color: ${color}`}>{count.toLocaleString()}</p>
            <p class="text-xs text-gray-400 mt-1" {...i18n('home.sectors.unit')}></p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- Why This Matters -->
  <section class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 mt-20 mb-8">
    <div class="bg-gradient-to-br from-primary-50 to-primary-100 rounded-2xl p-8 md:p-12 border border-primary-200">
      <div class="max-w-3xl mx-auto text-center">
        <h2 class="text-2xl md:text-3xl font-bold text-primary-900" {...i18n('home.why.title')}></h2>
        <div class="mt-8 grid md:grid-cols-3 gap-8 text-left">
          <div>
            <div class="w-10 h-10 bg-primary-200 rounded-lg flex items-center justify-center text-primary-700 font-bold text-lg mb-3">1</div>
            <h3 class="font-semibold text-primary-900" {...i18n('home.why.giving.title')}></h3>
            <p class="text-sm text-primary-700 mt-1" {...i18n('home.why.giving.text')}></p>
          </div>
          <div>
            <div class="w-10 h-10 bg-primary-200 rounded-lg flex items-center justify-center text-primary-700 font-bold text-lg mb-3">2</div>
            <h3 class="font-semibold text-primary-900" {...i18n('home.why.ipc.title')}></h3>
            <p class="text-sm text-primary-700 mt-1" {...i18nVar('home.why.ipc.text', { pct: Math.round(stats.ipc_active / stats.active * 100) })}></p>
          </div>
          <div>
            <div class="w-10 h-10 bg-primary-200 rounded-lg flex items-center justify-center text-primary-700 font-bold text-lg mb-3">3</div>
            <h3 class="font-semibold text-primary-900" {...i18n('home.why.gaps.title')}></h3>
            <p class="text-sm text-primary-700 mt-1" {...i18n('home.why.gaps.text')}></p>
          </div>
        </div>
      </div>
    </div>
  </section>

</Base>

<script>
  document.getElementById('search-form')?.addEventListener('submit', (e) => {
    e.preventDefault();
    const input = document.getElementById('search-input') as HTMLInputElement;
    const q = input?.value.trim();
    if (q) {
      window.location.href = `/charities/?q=${encodeURIComponent(q)}`;
    }
  });
</script>
