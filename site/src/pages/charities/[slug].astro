---
import Base from '../../layouts/Base.astro';
import { t, tVar, i18n, i18nVar } from '../../i18n/utils';
import { getActiveCharities, formatCurrency, stripHtml, SECTOR_COLORS, SECTOR_ICONS } from '../../data/load';
import type { Charity } from '../../data/load';

export function getStaticPaths() {
  const charities = getActiveCharities();
  return charities.map(c => ({
    params: { slug: c.slug },
    props: { charity: c },
  }));
}

interface Props {
  charity: Charity;
}

const { charity } = Astro.props;

const sectorColor = charity.sector ? SECTOR_COLORS[charity.sector] || '#6b7280' : '#6b7280';
const sectorIcon = charity.sector ? SECTOR_ICONS[charity.sector] || '' : '';

const description = stripHtml(charity.objective) || stripHtml(charity.vision_mission) || charity.givingsg_description || `Details for ${charity.name}`;
const truncatedDesc = description.length > 160 ? description.slice(0, 157) + '...' : description;

const objectiveText = stripHtml(charity.objective);
const visionText = stripHtml(charity.vision_mission);
const fallbackDesc = charity.givingsg_description;

const hasContact = charity.address || charity.phone || charity.email || charity.website;
const hasFinancials = charity.has_public_financials && charity.financials?.summaries?.length;
const hasGovernance = charity.governing_members_count > 0 || charity.key_officers_count > 0;
const hasClassifications = charity.classifications?.length > 0;
const hasActivities = charity.activities?.length > 0;
const hasCauses = charity.givingsg_causes?.length > 0;

const topGoverning = charity.governing_members?.slice(0, 5) || [];
const topOfficers = charity.key_officers?.slice(0, 5) || [];

function formatDate(dateStr: string | null): string {
  if (!dateStr) return '-';
  try {
    return new Date(dateStr).toLocaleDateString('en-SG', { year: 'numeric', month: 'short', day: 'numeric' });
  } catch {
    return dateStr;
  }
}

function ensureUrl(url: string | null): string {
  if (!url) return '';
  if (url.startsWith('http://') || url.startsWith('https://')) return url;
  return 'https://' + url;
}
---

<Base title={charity.name} description={truncatedDesc}>
  <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">

    <!-- Back link -->
    <a href="/charities/" class="inline-flex items-center gap-1 text-sm text-primary-600 hover:text-primary-700 mb-6 transition">
      <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
      <span {...i18n('detail.back')}>Back to Directory</span>
    </a>

    <!-- Header -->
    <header class="mb-8">
      <div class="flex flex-wrap items-start gap-3 mb-3">
        {charity.sector && (
          <span
            class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium text-white"
            style={`background-color: ${sectorColor}`}
          >
            <span>{sectorIcon}</span>
            {charity.sector}
          </span>
        )}
        {charity.ipc_status === 'Live' && (
          <span class="inline-flex items-center gap-1 px-3 py-1 rounded-full text-sm font-medium bg-green-100 text-green-800">
            <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd"/></svg>
            <span {...i18n('detail.ipc.approved')}>IPC Approved</span>
          </span>
        )}
        {charity.status === 'Registered with IPC' && charity.ipc_valid_till && (
          <span class="text-xs text-gray-500" {...i18nVar('detail.ipc.valid', { date: formatDate(charity.ipc_valid_till) })}>
            IPC valid till {formatDate(charity.ipc_valid_till)}
          </span>
        )}
      </div>
      <h1 class="text-2xl sm:text-3xl font-bold text-gray-900 mb-2">{charity.name}</h1>
      <p class="text-sm text-gray-500 font-mono">UEN: {charity.uen}</p>
    </header>

    <!-- Overview -->
    {(objectiveText || visionText || fallbackDesc) && (
      <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4" {...i18n('detail.overview')}>Overview</h2>

        {objectiveText && (
          <div class="mb-4">
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2" {...i18n('detail.objective')}>Objective</h3>
            <p class="text-gray-700 whitespace-pre-line leading-relaxed">{objectiveText}</p>
          </div>
        )}

        {visionText && (
          <div class="mb-4">
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2" {...i18n('detail.vision')}>Vision & Mission</h3>
            <p class="text-gray-700 whitespace-pre-line leading-relaxed">{visionText}</p>
          </div>
        )}

        {!objectiveText && !visionText && fallbackDesc && (
          <div>
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2" {...i18n('detail.description')}>Description</h3>
            <p class="text-gray-700 leading-relaxed">{fallbackDesc}</p>
            <p class="text-xs text-gray-400 mt-2" {...i18n('detail.source.givingsg')}>Source: giving.sg</p>
          </div>
        )}
      </section>
    )}

    <!-- Key Info Grid -->
    <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
      <h2 class="text-lg font-semibold text-gray-900 mb-4" {...i18n('detail.keyinfo')}>Key Information</h2>
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <div class="flex flex-col">
          <span class="text-sm text-gray-500" {...i18n('detail.reg_date')}>Registration Date</span>
          <span class="font-medium text-gray-900">{formatDate(charity.registration_date)}</span>
        </div>
        <div class="flex flex-col">
          <span class="text-sm text-gray-500" {...i18n('detail.org_type')}>Organisation Type</span>
          <span class="font-medium text-gray-900">{charity.setup || '-'}</span>
        </div>
        <div class="flex flex-col">
          <span class="text-sm text-gray-500" {...i18n('detail.sector_admin')}>Sector Administrator</span>
          <span class="font-medium text-gray-900">{charity.administrator || '-'}</span>
        </div>
        <div class="flex flex-col">
          <span class="text-sm text-gray-500" {...i18n('detail.postal_code')}>Postal Code</span>
          <span class="font-medium text-gray-900">{charity.postal_code || '-'}</span>
        </div>
      </div>
    </section>

    <!-- Contact Info -->
    {hasContact && (
      <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4" {...i18n('detail.contact')}>Contact</h2>
        <div class="space-y-3">
          {charity.address && (
            <div class="flex items-start gap-3">
              <svg class="w-5 h-5 text-gray-400 mt-0.5 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
              <span class="text-gray-700">{charity.address}{charity.postal_code ? `, Singapore ${charity.postal_code}` : ''}</span>
            </div>
          )}
          {charity.phone && (
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
              <a href={`tel:${charity.phone}`} class="text-primary-600 hover:text-primary-700 transition">{charity.phone}</a>
            </div>
          )}
          {charity.email && (
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
              <a href={`mailto:${charity.email}`} class="text-primary-600 hover:text-primary-700 transition break-all">{charity.email}</a>
            </div>
          )}
          {charity.website && (
            <div class="flex items-center gap-3">
              <svg class="w-5 h-5 text-gray-400 shrink-0" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 12a9 9 0 01-9 9m9-9a9 9 0 00-9-9m9 9H3m9 9a9 9 0 01-9-9m9 9c1.657 0 3-4.03 3-9s-1.343-9-3-9m0 18c-1.657 0-3-4.03-3-9s1.343-9 3-9m-9 9a9 9 0 019-9"/></svg>
              <a href={ensureUrl(charity.website)} target="_blank" rel="noopener noreferrer" class="text-primary-600 hover:text-primary-700 transition break-all">
                {charity.website}
                <svg class="w-3 h-3 inline ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
              </a>
            </div>
          )}
        </div>
      </section>
    )}

    <!-- Financial Summary -->
    {hasFinancials && (
      <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4" {...i18n('detail.financials')}>Financial Summary</h2>
        <div class="overflow-x-auto">
          <table class="w-full text-sm">
            <thead>
              <tr class="border-b border-gray-200">
                <th class="text-left py-3 px-2 font-medium text-gray-500" {...i18n('detail.fin.period')}>Period</th>
                <th class="text-right py-3 px-2 font-medium text-gray-500" {...i18n('detail.fin.income')}>Income</th>
                <th class="text-right py-3 px-2 font-medium text-gray-500" {...i18n('detail.fin.spending')}>Spending</th>
                <th class="text-right py-3 px-2 font-medium text-gray-500" {...i18n('detail.fin.surplus')}>Surplus / Deficit</th>
              </tr>
            </thead>
            <tbody>
              {charity.financials!.summaries.map(s => {
                const surplus = (s.income != null && s.spending != null) ? s.income - s.spending : null;
                return (
                  <tr class="border-b border-gray-100 hover:bg-gray-50">
                    <td class="py-3 px-2 text-gray-900">{s.period}</td>
                    <td class="py-3 px-2 text-right text-gray-700 font-mono">{formatCurrency(s.income)}</td>
                    <td class="py-3 px-2 text-right text-gray-700 font-mono">{formatCurrency(s.spending)}</td>
                    <td class:list={['py-3 px-2 text-right font-mono', surplus != null && surplus >= 0 ? 'text-green-600' : 'text-red-600']}>
                      {surplus != null ? formatCurrency(surplus) : '-'}
                    </td>
                  </tr>
                );
              })}
            </tbody>
          </table>
        </div>
        <p class="text-xs text-gray-400 mt-3" {...i18n('detail.fin.source')}>Source: charities.gov.sg public financial data</p>
      </section>
    )}

    <!-- Governance -->
    {hasGovernance && (
      <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-4" {...i18n('detail.governance')}>Governance</h2>
        <div class="grid grid-cols-2 gap-4 mb-5">
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-2xl font-bold text-gray-900">{charity.governing_members_count}</div>
            <div class="text-sm text-gray-500" {...i18n('detail.gov.members')}>Governing Members</div>
          </div>
          <div class="bg-gray-50 rounded-lg p-4 text-center">
            <div class="text-2xl font-bold text-gray-900">{charity.key_officers_count}</div>
            <div class="text-sm text-gray-500" {...i18n('detail.gov.officers')}>Key Officers</div>
          </div>
        </div>

        {topGoverning.length > 0 && (
          <div class="mb-4">
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2" {...i18n('detail.gov.members')}>Governing Members</h3>
            <ul class="space-y-1">
              {topGoverning.map(m => (
                <li class="text-sm text-gray-700">
                  <span class="font-medium">{m.name}</span>
                  {m.designation && <span class="text-gray-400"> &mdash; {m.designation}</span>}
                </li>
              ))}
            </ul>
            {charity.governing_members_count > 5 && (
              <p class="text-xs text-gray-400 mt-1" {...i18nVar('detail.gov.more', { count: charity.governing_members_count - 5 })}>and {charity.governing_members_count - 5} more</p>
            )}
          </div>
        )}

        {topOfficers.length > 0 && (
          <div>
            <h3 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-2" {...i18n('detail.gov.officers')}>Key Officers</h3>
            <ul class="space-y-1">
              {topOfficers.map(m => (
                <li class="text-sm text-gray-700">
                  <span class="font-medium">{m.name}</span>
                  {m.designation && <span class="text-gray-400"> &mdash; {m.designation}</span>}
                </li>
              ))}
            </ul>
            {charity.key_officers_count > 5 && (
              <p class="text-xs text-gray-400 mt-1" {...i18nVar('detail.gov.more', { count: charity.key_officers_count - 5 })}>and {charity.key_officers_count - 5} more</p>
            )}
          </div>
        )}
      </section>
    )}

    <!-- Classifications & Activities -->
    {(hasClassifications || hasActivities) && (
      <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
        {hasClassifications && (
          <div class="mb-5">
            <h2 class="text-lg font-semibold text-gray-900 mb-3" {...i18n('detail.classifications')}>Classifications</h2>
            <div class="flex flex-wrap gap-2">
              {charity.classifications.map(c => (
                <span class="inline-block px-3 py-1 rounded-full text-sm bg-blue-50 text-blue-700 border border-blue-200">{c}</span>
              ))}
            </div>
          </div>
        )}

        {hasActivities && (
          <div>
            <h2 class="text-lg font-semibold text-gray-900 mb-3" {...i18n('detail.activities')}>Activities</h2>
            <div class="flex flex-wrap gap-2">
              {charity.activities.map(a => (
                <span class="inline-block px-3 py-1 rounded-full text-sm bg-amber-50 text-amber-700 border border-amber-200">{a}</span>
              ))}
            </div>
          </div>
        )}
      </section>
    )}

    <!-- Giving.sg Causes -->
    {hasCauses && (
      <section class="bg-white rounded-xl border border-gray-200 p-6 mb-6">
        <h2 class="text-lg font-semibold text-gray-900 mb-3" {...i18n('detail.causes')}>Causes</h2>
        <div class="flex flex-wrap gap-2">
          {charity.givingsg_causes.map(c => (
            <span class="inline-block px-3 py-1 rounded-full text-sm bg-purple-50 text-purple-700 border border-purple-200">{c}</span>
          ))}
        </div>
        <p class="text-xs text-gray-400 mt-3" {...i18n('detail.source.givingsg')}>Source: giving.sg</p>
      </section>
    )}

    <!-- External Links -->
    <section class="bg-gray-100 rounded-xl p-6 mb-6">
      <h2 class="text-sm font-medium text-gray-500 uppercase tracking-wide mb-3" {...i18n('detail.external')}>External Links</h2>
      <div class="flex flex-wrap gap-3">
        <a
          href={`https://www.charities.gov.sg/charity/details/${charity.uen}`}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-flex items-center gap-1 px-4 py-2 bg-white rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 border border-gray-200 transition"
        >
          charities.gov.sg
          <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
        </a>
        {charity.givingsg_url && (
          <a
            href={charity.givingsg_url}
            target="_blank"
            rel="noopener noreferrer"
            class="inline-flex items-center gap-1 px-4 py-2 bg-white rounded-lg text-sm font-medium text-gray-700 hover:bg-gray-50 border border-gray-200 transition"
          >
            giving.sg
            <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 6H6a2 2 0 00-2 2v10a2 2 0 002 2h10a2 2 0 002-2v-4M14 4h6m0 0v6m0-6L10 14"/></svg>
          </a>
        )}
      </div>
    </section>

    <!-- Back to directory -->
    <div class="text-center">
      <a href="/charities/" class="inline-flex items-center gap-2 text-sm text-primary-600 hover:text-primary-700 font-medium transition">
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
        <span {...i18n('detail.back')}>Back to Directory</span>
      </a>
    </div>

  </div>
</Base>
