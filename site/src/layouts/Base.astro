---
import { t } from '../i18n/utils';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Explore Singapore\'s 2,600+ registered charities — search, filter, compare financials, and discover IPC-approved organisations.' } = Astro.props;
const currentPath = Astro.url.pathname;
const base = import.meta.env.BASE_URL.replace(/\/?$/, '/');

const navItems = [
  { href: base, label: 'Home', labelZh: '首页' },
  { href: `${base}charities/`, label: 'Directory', labelZh: '目录' },
  { href: `${base}dashboard/`, label: 'Dashboard', labelZh: '全景' },
  { href: `${base}about/`, label: 'About', labelZh: '关于' },
];
---

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | SG Charity Map</title>
  <link rel="canonical" href={`https://meltflake.com${Astro.url.pathname}`} />
  <!-- Open Graph -->
  <meta property="og:title" content={`${title} | SG Charity Map`} />
  <meta property="og:description" content={description} />
  <meta property="og:url" content={`https://meltflake.com${Astro.url.pathname}`} />
  <meta property="og:site_name" content="SG Charity Map" />
  <meta property="og:locale" content="en_SG" />
  <meta property="og:type" content="website" />
  <!-- Twitter Card -->
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content={`${title} | SG Charity Map`} />
  <meta name="twitter:description" content={description} />
  <link rel="sitemap" href="/sg-charity/sitemap-index.xml" />
  <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
  <script is:inline define:vars={{ base }}>
    window.__BASE = base;
    if(localStorage.getItem('sg-charity-lang')==='zh'){document.documentElement.dataset.lang='zh';document.documentElement.lang='zh'}
  </script>
  <!-- Google Analytics -->
  <script async src="https://www.googletagmanager.com/gtag/js?id=G-6QWH6QHG2X"></script>
  <script is:inline>window.dataLayer=window.dataLayer||[];function gtag(){dataLayer.push(arguments);}gtag('js',new Date());gtag('config','G-6QWH6QHG2X');</script>
</head>
<body class="bg-gray-50 text-gray-900 min-h-screen flex flex-col">
  <header class="bg-white border-b border-gray-200 sticky top-0 z-50">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex justify-between items-center h-16">
        <a href={base} class="flex items-center gap-2 font-bold text-xl text-primary-700 hover:text-primary-600 transition">
          <span class="text-2xl">🗺️</span>
          <span>SG Charity Map</span>
        </a>
        <nav class="hidden md:flex items-center gap-1">
          {navItems.map(item => (
            <a
              href={item.href}
              class:list={[
                'px-3 py-2 rounded-lg text-sm font-medium transition',
                currentPath === item.href || (item.href !== '/' && currentPath.startsWith(item.href))
                  ? 'bg-primary-50 text-primary-700'
                  : 'text-gray-600 hover:text-gray-900 hover:bg-gray-100',
              ]}
            >
              <span data-i18n data-en={item.label} data-zh={item.labelZh}>{item.label}</span>
            </a>
          ))}
          <button class="lang-toggle-btn ml-3 px-2.5 py-1.5 rounded-md text-sm font-medium border border-gray-300 text-gray-600 hover:bg-gray-100 transition" aria-label="Switch language">
            中文
          </button>
        </nav>
        <button id="mobile-menu-btn" class="md:hidden p-2 rounded-lg hover:bg-gray-100" aria-label="Menu">
          <svg class="w-6 h-6" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
        </button>
      </div>
    </div>
    <nav id="mobile-menu" class="hidden md:hidden border-t border-gray-200 bg-white">
      <div class="px-4 py-2 space-y-1">
        {navItems.map(item => (
          <a href={item.href} class="block px-3 py-2 rounded-lg text-sm font-medium text-gray-600 hover:text-gray-900 hover:bg-gray-100">
            <span data-i18n data-en={item.label} data-zh={item.labelZh}>{item.label}</span>
          </a>
        ))}
        <button class="lang-toggle-btn w-full mt-2 px-3 py-2 rounded-lg text-sm font-medium border border-gray-300 text-gray-600 hover:bg-gray-100 transition" aria-label="Switch language">
          中文
        </button>
      </div>
    </nav>
  </header>

  <main class="flex-1">
    <slot />
  </main>

  <footer class="bg-white border-t border-gray-200 mt-12">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
      <div class="flex flex-col md:flex-row justify-between items-center gap-4 text-sm text-gray-500">
        <div>
          <p class="font-medium text-gray-700"><span data-i18n data-en="SG Charity Map — Singapore Charity Panorama" data-zh="SG Charity Map — 新加坡公益全景">SG Charity Map — 新加坡公益全景</span></p>
          <p><span data-i18n data-en="Data sourced from charities.gov.sg, data.gov.sg, giving.sg" data-zh="数据来源：charities.gov.sg、data.gov.sg、giving.sg">Data sourced from charities.gov.sg, data.gov.sg, giving.sg</span></p>
        </div>
        <div class="text-right">
          <p><span data-i18n data-en="Open data project for public benefit" data-zh="服务公众的开放数据项目">Open data project for public benefit</span></p>
          <p><span data-i18n data-en="Not affiliated with any government agency" data-zh="与任何政府机构无关">Not affiliated with any government agency</span></p>
        </div>
      </div>
    </div>
  </footer>

  <script>
    document.getElementById('mobile-menu-btn')?.addEventListener('click', () => {
      document.getElementById('mobile-menu')?.classList.toggle('hidden');
    });
  </script>

  <script is:inline>
  (function(){
    var SK='sg-charity-lang',html=document.documentElement;
    function apply(l){
      html.lang=l;html.dataset.lang=l;
      localStorage.setItem(SK,l);
      document.querySelectorAll('[data-i18n]').forEach(function(el){
        var t=el.getAttribute('data-'+l);
        if(t!==null)el.textContent=t;
      });
      document.querySelectorAll('[data-i18n-placeholder]').forEach(function(el){
        var t=el.getAttribute('data-placeholder-'+l);
        if(t)el.placeholder=t;
      });
      document.querySelectorAll('[data-i18n-option]').forEach(function(el){
        var t=el.getAttribute('data-'+l);
        if(t!==null)el.textContent=t;
      });
      document.querySelectorAll('.lang-toggle-btn').forEach(function(b){
        b.textContent=l==='en'?'中文':'EN';
      });
    }
    var lang=localStorage.getItem(SK)==='zh'?'zh':'en';
    apply(lang);
    document.querySelectorAll('.lang-toggle-btn').forEach(function(b){
      b.addEventListener('click',function(){
        apply(html.dataset.lang==='en'?'zh':'en');
      });
    });
  })();
  </script>
</body>
</html>
